# Copy on server: cp .env.production.example .env
# Then: php artisan key:generate  (only if APP_KEY is empty)

APP_NAME=90plus
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_TIMEZONE=Asia/Almaty
APP_URL=https://90plus.kz

# Secret for public/plesk-deploy.php (Plesk cron "Run PHP script")
DEPLOY_KEY=change-me-to-long-random-string

APP_LOCALE=kk
APP_FALLBACK_LOCALE=en

LOG_CHANNEL=stack
LOG_LEVEL=error

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=90plus
DB_USERNAME=
DB_PASSWORD=

SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_SECURE_COOKIE=true
SESSION_DOMAIN=null

QUEUE_CONNECTION=database
CACHE_STORE=file

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

TRANSLATION_DRIVER=google
LIBRETRANSLATE_URL=https://libretranslate.com/translate
LIBRETRANSLATE_API_KEY=

ARTICLE_FETCH_INTERVAL=60

API_FOOTBALL_KEY=

# Server: Laravel 11 needs PHP 8.2+. In Plesk use PHP 8.3 (not system php 8.0).
# composer: /opt/plesk/php/8.3/bin/php $(which composer) install --no-dev
