APP_NAME=90plus
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=Asia/Almaty
APP_URL=http://localhost:8000

# Production (90plus.kz): copy .env.production.example → .env on server

APP_LOCALE=kk
APP_FALLBACK_LOCALE=en

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=90plus
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=file
QUEUE_CONNECTION=database
CACHE_STORE=file

# Translation: google (free unofficial) or libre
TRANSLATION_DRIVER=google
LIBRETRANSLATE_URL=https://libretranslate.com/translate
LIBRETRANSLATE_API_KEY=

# Article fetch interval (minutes) — scheduler runs articles:fetch-hourly every hour
ARTICLE_FETCH_INTERVAL=60

# Football data via API-Football (api-football.com)
API_FOOTBALL_KEY=
